# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Agency access (comma-separated emails allowed to use /dashboard)
AGENCY_ADMIN_EMAILS=you@yourdomain.com

# Dashboard gate (development only — not used in production auth)
DASHBOARD_PASSWORD=your-dashboard-password

# Supabase (all three required for production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Strategy call booking (optional — contact form still works without it)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link/30min

# OpenAI (AI lead follow-up assistant)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Notifications (recommended — instant alerts on form submission)
NOTIFICATION_EMAIL=admin@youragency.com
NOTIFICATION_FROM=LUPIN LEADS <notifications@lupinleads.com>
RESEND_API_KEY=re_...
NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/...

# Meta Lead Ads webhook (see docs/META_LEAD_SETUP.md)
META_VERIFY_TOKEN=your-random-verify-token
META_APP_SECRET=your-meta-app-secret
META_GRAPH_ACCESS_TOKEN=your-page-access-token-with-leads_retrieval

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_SCOUT=price_...
STRIPE_PRICE_ALPHA=price_...
STRIPE_PRICE_PACK=price_...
